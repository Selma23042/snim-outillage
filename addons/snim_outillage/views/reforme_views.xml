<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Vue liste -->
  <record id="view_reforme_list" model="ir.ui.view">
    <field name="name">snim.reforme.list</field>
    <field name="model">snim.reforme</field>
    <field name="arch" type="xml">
      <list string="Reformes"
            decoration-muted="date_reforme != False">
        <field name="name"/>
        <field name="instrument_id"/>
        <field name="date_reforme"/>
        <field name="motif"/>
      </list>
    </field>
  </record>

  <!-- Vue formulaire -->
  <record id="view_reforme_form" model="ir.ui.view">
    <field name="name">snim.reforme.form</field>
    <field name="model">snim.reforme</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" readonly="1"/>
            </h1>
          </div>
          <group>
            <group string="Informations reforme">
              <field name="instrument_id"/>
              <field name="date_reforme"/>
            </group>
          </group>
          <group string="Motif de la reforme">
            <field name="motif"
                   nolabel="1"
                   colspan="2"
                   placeholder="Expliquer la raison de la mise en reforme..."/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_reforme" model="ir.actions.act_window">
    <field name="name">Reformes</field>
    <field name="res_model">snim.reforme</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>